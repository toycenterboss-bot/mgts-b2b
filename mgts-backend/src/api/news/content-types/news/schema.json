{
  "kind": "collectionType",
  "collectionName": "news",
  "info": {
    "singularName": "news",
    "pluralName": "news-items",
    "displayName": "News",
    "description": "Новости компании"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "shortDescription": {
      "type": "text",
      "required": true
    },
    "content": {
      "type": "richtext",
      "required": true
    },
    "featuredImage": {
      "type": "media",
      "multiple": false,
      "required": false
    },
    "gallery": {
      "type": "media",
      "multiple": true
    },
    "publishDate": {
      "type": "datetime",
      "required": true
    },
    "author": {
      "type": "string"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::news-category.news-category"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::news-tag.news-tag"
    },
    "isFeatured": {
      "type": "boolean",
      "default": false
    },
    "viewsCount": {
      "type": "integer",
      "default": 0
    },
    "metaDescription": {
      "type": "text"
    },
    "metaKeywords": {
      "type": "string"
    }
  }
}

